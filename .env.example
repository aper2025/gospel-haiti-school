# ════════════════════════════════════════════════════════════════
# Gospel Haiti International School — Environment variables
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the real values.
# Never commit .env to git (already in .gitignore).

# ─── Supabase / Postgres ─────────────────────────────────────────
# Pooled connection for the app (through pgBouncer/Supavisor).
# Shape: postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres?pgbouncer=true"

# Direct connection used by Prisma Migrate.
# Shape: postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://postgres:password@localhost:5432/postgres"

# ─── Supabase client (browser + server) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."   # server-only; never expose to client

# ─── Auth ────────────────────────────────────────────────────────
# 32+ random chars (e.g. `openssl rand -base64 48`)
AUTH_SECRET="replace-me-with-a-long-random-string"

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://portal.gospelhaiti.org"
NEXT_PUBLIC_DEFAULT_LOCALE="fr"

# ─── Optional: email/SMS for alerts (later) ──────────────────────
# RESEND_API_KEY=""
# TWILIO_ACCOUNT_SID=""
